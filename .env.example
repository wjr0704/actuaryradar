# ActuaryRadar environment variables
# Copy this file to .env locally and fill in real values.
# Do not commit real credentials.

# Optional: email digest delivery
GMAIL_ADDRESS=your_email@example.com
GMAIL_APP_PASSWORD=your_gmail_app_password
ACTUARY_DIGEST_EMAIL_FROM=your_email@example.com
ACTUARY_DIGEST_EMAIL_PASSWORD=your_email_password

# Optional: authoritative-source search providers
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=your_tavily_api_key
BING_WEB_SEARCH_API_KEY=your_bing_web_search_api_key
SERPAPI_API_KEY=your_serpapi_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_MODEL=sonar

# Optional future backend
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Deployment
SITE_BASE_URL=https://insuranceactuaryhub.com
